desc: Block Counter

@init
// Reset the block counter to 0 every time playback starts
block_count = 0;

@block
// On every new block, increment the counter by 1
block_count = block_count + 1;

@gfx 300 50
// Set the font and color
gfx_setfont(1, "Arial", 14);
gfx_r = 1; gfx_g = 1; gfx_b = 1; gfx_a = 1;

// Set the poisition of the counter
gfx_x = 10;
gfx_y = 10;

// Print the counter
gfx_printf("Counter: %d", block_count);
